<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/trainingrequest/db" VERSION="2026040500" COMMENT="Training Request System">

    <TABLES>

        <TABLE NAME="training_requests" COMMENT="Stores all training requests">

            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="50" NOTNULL="true" DEFAULT="draft"/>
                <FIELD NAME="priority" TYPE="char" LENGTH="20" NOTNULL="false" DEFAULT="medium"/>
                <FIELD NAME="facultyid" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="approvedby" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timeapproved" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timestart" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="timeend" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="certificate_path" TYPE="char" LENGTH="255" NOTNULL="false"/>
                <FIELD NAME="remarks" TYPE="text" NOTNULL="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
                <INDEX NAME="status_idx" UNIQUE="false" FIELDS="status"/>
                <INDEX NAME="faculty_idx" UNIQUE="false" FIELDS="facultyid"/>
            </INDEXES>

        </TABLE>

    </TABLES>

</XMLDB>
